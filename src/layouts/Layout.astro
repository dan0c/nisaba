---
interface Props {
  title?: string;
  lang?: string;
  stickyNav?: boolean;
}
const {
  title = 'Nisaba — École de français à Chalabre',
  lang = 'fr',
  stickyNav = false,
} = Astro.props;

const path = Astro.url.pathname;
const navLinks = [
  { href: '/cours',    label: 'Cours' },
  { href: '/a-propos', label: 'À propos' },
  { href: '/contact',  label: 'Contact' },
];
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-linen text-ink font-body antialiased">

    <header class:list={[
      'z-50 border-b border-warm-grey bg-linen',
      stickyNav ? 'fixed top-0 inset-x-0 bg-linen/95 backdrop-blur-sm' : '',
    ]}>
      <div class="max-w-[1180px] mx-auto px-6 lg:px-14 h-16 flex items-center justify-between">

        <a href="/" class="font-display text-2xl text-ink tracking-tight">Nisaba</a>

        <nav class="items-center gap-6 sm:gap-8 hidden sm:flex">
          {navLinks.map(({ href, label }) => {
            const active = path === href || path.startsWith(href + '/');
            return (
              <a
                href={href}
                class:list={[
                  'text-sm transition-colors',
                  active ? 'font-semibold text-ink' : 'text-ink/60 hover:text-ink',
                ]}
                aria-current={active ? 'page' : undefined}
              >
                {label}
              </a>
            );
          })}

          <div class="flex items-center gap-1.5 text-sm ml-2 pl-5 border-l border-warm-grey">
            <button class="font-semibold text-ink cursor-default" aria-current="true">FR</button>
            <span class="text-ink/30">/</span>
            <button class="text-ink/50 hover:text-ink transition-colors">EN</button>
          </div>
        </nav>

        <button
          id="menu-open"
          type="button"
          class="sm:hidden flex items-center justify-center w-10 h-10 -mr-2"
          aria-label="Ouvrir le menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/></svg>
        </button>

      </div>
    </header>

    <!-- ── Mobile full-screen menu ─────────────────────────────────────── -->
    <div
      id="mobile-menu"
      class="fixed inset-0 z-[60] bg-linen flex flex-col sm:hidden invisible opacity-0 transition-opacity duration-200"
    >
      <div class="max-w-[1180px] w-full mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/" class="font-display text-2xl text-ink tracking-tight">Nisaba</a>
        <button
          id="menu-close"
          type="button"
          class="flex items-center justify-center w-10 h-10 -mr-2"
          aria-label="Fermer le menu"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg>
        </button>
      </div>

      <nav class="flex-1 flex flex-col justify-center gap-2 px-6 -mt-16">
        {navLinks.map(({ href, label }) => {
          const active = path === href || path.startsWith(href + '/');
          return (
            <a
              href={href}
              class:list={[
                'font-display text-4xl py-3 transition-colors',
                active ? 'text-sage' : 'text-ink hover:text-sage',
              ]}
              aria-current={active ? 'page' : undefined}
            >
              {label}
            </a>
          );
        })}
      </nav>

      <div class="px-6 pb-10 flex items-center gap-2 text-base">
        <button class="font-semibold text-ink cursor-default" aria-current="true">FR</button>
        <span class="text-ink/30">/</span>
        <button class="text-ink/50 hover:text-ink transition-colors">EN</button>
      </div>
    </div>

    <script>
      const openBtn = document.getElementById('menu-open');
      const closeBtn = document.getElementById('menu-close');
      const menu = document.getElementById('mobile-menu');

      function openMenu() {
        menu?.classList.remove('invisible', 'opacity-0');
        openBtn?.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }

      function closeMenu() {
        menu?.classList.add('invisible', 'opacity-0');
        openBtn?.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }

      openBtn?.addEventListener('click', openMenu);
      closeBtn?.addEventListener('click', closeMenu);
      menu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMenu));
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeMenu();
      });
    </script>

    <slot />

  </body>
</html>
