---
import { routes, nav, footer, type Lang, type PageKey } from '../i18n/translations';
import ScribbleIcon from './ScribbleIcon.astro';

interface Props {
  lang: Lang;
  page: PageKey;
}
const { lang, page } = Astro.props;
const t = footer[lang];
const n = nav[lang];
const otherLang: Lang = lang === 'fr' ? 'en' : 'fr';

const navLinks = [
  { href: routes.cours[lang],   label: n.cours },
  { href: routes.aPropos[lang], label: n.aPropos },
  { href: routes.contact[lang], label: n.contact },
];
---

<footer class="bg-ink text-linen/70">
  <div class="max-w-[1180px] mx-auto px-6 lg:px-14 pt-13 pb-8 lg:pt-14">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-8">

      <a href={routes.home[lang]} class="flex items-center gap-2 font-display text-2xl text-linen tracking-tight">
        Nisaba
        <ScribbleIcon class="w-6 h-6 text-linen" />
      </a>

      <nav class="flex gap-7 text-sm">
        {navLinks.map(({ href, label }) => (
          <a href={href} class="hover:text-linen transition-colors">{label}</a>
        ))}
      </nav>

      <div class="flex flex-col gap-4 md:items-end">
        <div class="flex gap-3">
          <a
            href="#"
            aria-label="Instagram"
            class="w-[34px] h-[34px] rounded-full border border-white/20 flex items-center justify-center hover:border-white/50 hover:text-linen transition-colors"
          >
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M12 2.2c3.2 0 3.6 0 4.9.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.86s0 3.6-.07 4.86c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.9.07s-3.6 0-4.86-.07c-1.17-.05-1.8-.25-2.23-.41a3.72 3.72 0 01-1.38-.9 3.72 3.72 0 01-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.2 15.6 2.2 15.2 2.2 12s0-3.6.07-4.86c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.4 2.2 8.8 2.2 12 2.2zm0 1.98c-3.14 0-3.51.01-4.75.07-.9.04-1.38.19-1.71.32-.43.17-.74.37-1.06.69-.32.32-.52.63-.69 1.06-.13.33-.28.81-.32 1.71-.06 1.24-.07 1.61-.07 4.75s.01 3.51.07 4.75c.04.9.19 1.38.32 1.71.17.43.37.74.69 1.06.32.32.63.52 1.06.69.33.13.81.28 1.71.32 1.24.06 1.61.07 4.75.07s3.51-.01 4.75-.07c.9-.04 1.38-.19 1.71-.32.43-.17.74-.37 1.06-.69.32-.32.52-.63.69-1.06.13-.33.28-.81.32-1.71.06-1.24.07-1.61.07-4.75s-.01-3.51-.07-4.75c-.04-.9-.19-1.38-.32-1.71a2.86 2.86 0 00-.69-1.06 2.86 2.86 0 00-1.06-.69c-.33-.13-.81-.28-1.71-.32-1.24-.06-1.61-.07-4.75-.07zm0 3.38a4.44 4.44 0 110 8.88 4.44 4.44 0 010-8.88zm0 7.32a2.88 2.88 0 100-5.76 2.88 2.88 0 000 5.76zm5.65-7.5a1.04 1.04 0 11-2.08 0 1.04 1.04 0 012.08 0z"/></svg>
          </a>
          <a
            href="#"
            aria-label="Facebook"
            class="w-[34px] h-[34px] rounded-full border border-white/20 flex items-center justify-center hover:border-white/50 hover:text-linen transition-colors"
          >
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M22 12a10 10 0 10-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0022 12z"/></svg>
          </a>
          <a
            href="mailto:contact@nisaba.fr"
            aria-label="Email"
            class="w-[34px] h-[34px] rounded-full border border-white/20 flex items-center justify-center hover:border-white/50 hover:text-linen transition-colors"
          >
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M20 4H4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V6a2 2 0 00-2-2zm0 4l-8 5-8-5V6l8 5 8-5z"/></svg>
          </a>
        </div>

        <div class="text-sm">
          {lang === 'fr' ? (
            <span class="font-semibold text-linen">FR</span>
          ) : (
            <a href={routes[page][otherLang]} class="hover:text-linen transition-colors">FR</a>
          )}
          <span class="mx-1 text-white/30">/</span>
          {lang === 'en' ? (
            <span class="font-semibold text-linen">EN</span>
          ) : (
            <a href={routes[page][otherLang]} class="hover:text-linen transition-colors">EN</a>
          )}
        </div>
      </div>

    </div>

    <div class="mt-9 pt-5 border-t border-white/10 flex flex-col sm:flex-row sm:justify-between gap-2 text-xs">
      <span>{t.copyright}</span>
      <a href="#" class="hover:text-linen transition-colors">{t.legal}</a>
    </div>
  </div>
</footer>
