---
import Layout from '../../layouts/Layout.astro';
import { cours, routes, type Lang } from '../../i18n/translations';
import EverydayFrenchIcon from '../icons/EverydayFrenchIcon.astro';
import DelfIcon from '../icons/DelfIcon.astro';
import PronunciationIcon from '../icons/PronunciationIcon.astro';
import PrivateIcon from '../icons/PrivateIcon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = cours[lang];
const contactHref = routes.contact[lang];

const courseIcons = {
  c1: EverydayFrenchIcon,
  c2: DelfIcon,
  c3: PronunciationIcon,
  c4: PrivateIcon,
} as const;
---

<Layout title={t.title} page="cours" lang={lang}>

  <main>

    <!-- ── Hero ──────────────────────────────────────────────────────── -->
    <section>
      <div class="max-w-[1180px] mx-auto px-6 lg:px-14 pt-16 pb-10 lg:pt-20 lg:pb-10">
      <span class="block text-sm font-semibold text-sage mb-4">{t.heroEyebrow}</span>
      <h1 class="font-display text-5xl lg:text-[68px] leading-[.98] text-ink mb-5 tracking-[-0.01em]">
        {t.heroHeading}
      </h1>
      <p class="text-[17px] leading-[1.55] text-ink/60 max-w-[520px]">
        {t.heroSub}
      </p>
      </div>
    </section>

    <!-- ── Sticky subnav (desktop) ───────────────────────────────────── -->
    <nav class="hidden md:block sticky top-0 z-20 bg-sage border-t border-b border-black/15 shadow-[0_6px_18px_rgba(33,29,23,0.12)]">
      <div class="max-w-[1180px] mx-auto px-6 lg:px-14 flex gap-2.5">
        {t.courses.map((c) => (
          <a
            href={`#${c.id}`}
            class="py-5 px-4 first:-ml-4 text-[15px] font-semibold text-white/70 border-b-[3px] border-transparent hover:text-white hover:bg-white/[0.06] transition-colors whitespace-nowrap"
          >
            {c.name}
          </a>
        ))}
      </div>
    </nav>

    <!-- ── Mobile course menu (replaces subnav) ──────────────────────── -->
    <nav class="flex md:hidden flex-col gap-2.5 max-w-[1180px] mx-auto px-6 pt-6 pb-8">
      <h2 class="font-display text-[30px] leading-none text-ink mb-3">{t.heroEyebrow}</h2>
      {t.courses.map((c) => (
        <a
          href={`#${c.id}`}
          class="group flex flex-col gap-1 px-5 py-4 bg-warm-grey border border-black/5"
        >
          <span class="font-semibold text-[15px] text-sage underline-offset-[3px] group-hover:underline">{c.name}</span>
          <span class="text-[13px] text-ink/60">{c.blurb}</span>
        </a>
      ))}
    </nav>

    <!-- ── Inclus dans chaque formule ────────────────────────────────── -->
    <section class="bg-sage">
      <div class="max-w-[1180px] mx-auto px-6 lg:px-14 py-11 lg:py-12">
        <h2 class="font-display text-[30px] leading-none text-white mb-1">{t.includedHeading}</h2>
        <p class="text-[14px] text-white/70 mb-7">{t.includedSub}</p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-7 lg:gap-8">
          {t.included.map((item) => (
            <div>
              <div class="w-[7px] h-[7px] rounded-full bg-terracotta mb-3" aria-hidden="true" />
              <h4 class="text-[13px] font-semibold text-white mb-1.5">{item.title}</h4>
              <p class="text-[13px] leading-[1.5] text-white/70">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Course modules ────────────────────────────────────────────── -->
    {t.courses.map((course) => {
      const Icon = courseIcons[course.id as keyof typeof courseIcons];
      return (
      <section
        id={course.id}
        class:list={[
          'scroll-mt-[60px]',
          course.alt ? 'bg-warm-grey/50' : 'bg-linen',
        ]}
      >
        <div class="max-w-[1180px] mx-auto px-6 lg:px-14 py-12 lg:py-14">

          <!-- Module header -->
          <div class="max-w-2xl mb-9">
            <Icon class="w-16 h-16 text-terracotta mb-5" />
            <span class="block text-sm font-semibold text-sage mb-3">{course.eyebrow}</span>
            <h3 class="font-display text-[40px] leading-[1.02] text-ink mb-3">{course.name}</h3>
            <p class="text-[16px] leading-[1.55] text-ink/60">{course.summary}</p>
          </div>

          <!-- Module body: content + pricing card -->
          <div class="grid grid-cols-1 md:grid-cols-[1fr_300px] gap-12 items-start">

            <!-- Lists -->
            <div class:list={[
              'grid gap-10',
              course.programme ? 'grid-cols-1 sm:grid-cols-2' : 'grid-cols-1 max-w-[420px]',
            ]}>
              {course.programme && (
                <div>
                  <div class="text-sm font-semibold text-sage mb-4">{t.programmeLabel}</div>
                  <ul class="space-y-[11px]">
                    {course.programme.map((item) => (
                      <li class="relative pl-[17px] text-[14px] leading-[1.5] text-ink">
                        <span class="absolute left-0 top-[9px] w-[5px] h-[5px] rounded-full bg-terracotta" aria-hidden="true" />
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              )}
              <div>
                <div class="text-sm font-semibold text-sage mb-4">{t.howLabel}</div>
                <ul class="space-y-[11px]">
                  {course.how.map((item) => (
                    <li class="relative pl-[17px] text-[14px] leading-[1.5] text-ink">
                      <span class="absolute left-0 top-[9px] w-[5px] h-[5px] rounded-full bg-terracotta" aria-hidden="true" />
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <!-- Pricing card -->
            <aside class:list={[
              'border border-warm-grey rounded-[5px] p-6 flex flex-col gap-[18px]',
              course.alt ? 'bg-[#f6f1e9]' : 'bg-linen',
            ]}>
              <div>
                <div class="text-sm font-semibold text-sage mb-2">{course.freqLabel}</div>
                <div class="text-[13px] leading-[1.5] text-ink">{course.freq}</div>
              </div>
              <div class="pt-4 border-t border-warm-grey">
                <div class="font-display text-[42px] leading-none text-ink">
                  {course.price}
                  {course.priceUnit && (
                    <span class="text-[17px] text-ink/60">{course.priceUnit}</span>
                  )}
                </div>
                {course.priceNote && (
                  <p class="text-[12.5px] leading-[1.5] text-ink/60 mt-1.5">{course.priceNote}</p>
                )}
              </div>
              <a
                href={`${contactHref}?cours=${course.id}`}
                class="inline-flex items-center justify-center gap-2 bg-terracotta text-white text-[13.5px] font-semibold px-5 py-3 rounded-[3px] hover:bg-terracotta/85 transition-colors"
              >
                {t.ctaLabel}
              </a>
            </aside>

          </div>
        </div>
      </section>
      );
    })}

    <!-- ── Contact footer ────────────────────────────────────────────── -->
    <section class="bg-sage" id="contact">
      <div class="max-w-[1180px] mx-auto px-6 lg:px-14 py-20 lg:py-24 text-center">
      <h2 class="font-display text-[46px] leading-none text-white mb-4">{t.footerHeading}</h2>
      <p class="text-[16px] text-white/75 mb-8">{t.footerParagraph}</p>
      <a
        href={contactHref}
        class="inline-flex items-center gap-2 bg-terracotta text-white text-[13.5px] font-semibold px-5 py-3 rounded-[3px] hover:bg-terracotta/85 transition-colors"
      >
        {t.footerCta}
      </a>
      </div>
    </section>

  </main>

</Layout>
