---
import Layout from '../../layouts/Layout.astro';
import { home, routes, type Lang } from '../../i18n/translations';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = home[lang];
const coursHref = routes.cours[lang];
---

<Layout title={t.title} page="home" lang={lang} stickyNav={true}>

  <main>

    <!-- ── Hero ───────────────────────────────────────────────────────── -->
    <section class="min-h-screen flex items-center px-6 pt-16">
      <div class="max-w-5xl mx-auto py-24 lg:py-36">

        <p class="text-sm font-semibold text-sage mb-10">
          {t.eyebrow}
        </p>

        <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl text-ink leading-[1.1] mb-8">
          <span class="stroke-underline">{t.heroHighlight}</span>,<br />
          {t.heroRest}
        </h1>

        <p class="text-lg sm:text-xl text-ink/65 max-w-xl mb-12 leading-relaxed">
          {t.heroSub}
        </p>

        <a
          href={coursHref}
          class="inline-flex items-center gap-3 bg-terracotta text-white px-8 py-4 text-sm font-medium hover:bg-terracotta/90 transition-colors"
        >
          {t.heroCta}
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>

      </div>
    </section>

    <!-- ── Courses ─────────────────────────────────────────────────────── -->
    <section class="py-24 px-6" id="cours">
      <div class="max-w-6xl mx-auto">

        <div class="mb-14">
          <p class="text-sm font-semibold text-sage mb-3">{t.coursesEyebrow}</p>
          <h2 class="font-display text-4xl sm:text-5xl text-ink">{t.coursesHeading}</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {t.courses.map((course) => (
            <a
              href={`${coursHref}${course.anchor}`}
              class="group bg-warm-grey p-8 flex flex-col gap-5 border border-transparent hover:border-sage transition-all duration-300"
            >
              <span class="text-xs font-mono text-ink/25 tracking-widest">{course.number}</span>
              <h3 class="font-display text-xl text-ink leading-snug">{course.name}</h3>
              <p class="text-sm text-ink/60 leading-relaxed flex-1">{course.description}</p>
              <span class="flex items-center gap-1.5 text-sm text-sage font-medium group-hover:gap-2.5 transition-all duration-200">
                {t.coursesLinkLabel}
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </span>
            </a>
          ))}
        </div>

      </div>
    </section>

    <!-- ── About teaser ────────────────────────────────────────────────── -->
    <section class="py-24 px-6 bg-warm-grey/40">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

          <div>
            <p class="text-sm font-semibold text-sage mb-3">{t.aboutEyebrow}</p>
            <h2 class="font-display text-4xl sm:text-5xl text-ink leading-tight">
              {t.aboutHeadingLead}<br />
              <span class="stroke-underline">{t.aboutHeadingHighlight}</span>
            </h2>
          </div>

          <div>
            <p class="text-lg text-ink/75 leading-relaxed mb-5">
              {t.aboutParagraph1}
            </p>
            <p class="text-lg text-ink/75 leading-relaxed mb-10">
              {t.aboutParagraph2}
            </p>
            <a
              href={routes.aPropos[lang]}
              class="inline-flex items-center gap-2 text-sage font-medium hover:gap-3 transition-all duration-200"
            >
              {t.aboutLinkLabel}
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>

        </div>
      </div>
    </section>

    <!-- ── Contact CTA ─────────────────────────────────────────────────── -->
    <section class="py-24 px-6 bg-sage">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="font-display text-4xl sm:text-5xl text-linen leading-tight mb-5">
          {t.contactHeading}
        </h2>
        <p class="text-linen/65 text-lg leading-relaxed mb-10">
          {t.contactParagraph}
        </p>
        <a
          href={routes.contact[lang]}
          class="inline-flex items-center gap-3 bg-terracotta text-white px-8 py-4 text-sm font-medium hover:bg-terracotta/90 transition-colors"
        >
          {t.contactCta}
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </section>

  </main>

</Layout>
