---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';

const courses = [
  {
    number: '01',
    name: 'Le français au quotidien',
    description: 'Mairie, commerces, médecin, voisinage — le français qui sert vraiment dans la vie de Chalabre et du Quercorb.',
    href: '/cours#c1',
  },
  {
    number: '02',
    name: 'Préparation DELF B1/B2',
    description: 'Préparez votre diplôme officiel avec une méthode éprouvée et un suivi personnalisé à chaque étape.',
    href: '/cours#c2',
  },
  {
    number: '03',
    name: 'Ateliers Prononciation',
    description: 'Sons, intonation, rythme. Prenez confiance à l\'oral et parlez sans hésiter ni rougir.',
    href: '/cours#c3',
  },
  {
    number: '04',
    name: 'Cours Individuels',
    description: 'À votre rythme, selon vos objectifs. Une formule sur mesure, entièrement adaptée à vous.',
    href: '/cours#c4',
  },
];
---

<Layout title="Nisaba — École de français à Chalabre, Aude" stickyNav={true}>

  <main>

    <!-- ── Hero ───────────────────────────────────────────────────────── -->
    <section class="min-h-screen flex items-center px-6 pt-16">
      <div class="max-w-5xl mx-auto py-24 lg:py-36">

        <p class="text-sm font-semibold text-sage mb-10">
          École de français · Chalabre, Aude
        </p>

        <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl text-ink leading-[1.1] mb-8">
          <span class="stroke-underline">Vivez la France</span>,<br />
          ne la subissez&nbsp;pas.
        </h1>

        <p class="text-lg sm:text-xl text-ink/65 max-w-xl mb-12 leading-relaxed">
          Des cours de français pour s'intégrer vraiment dans la vie locale&nbsp;—
          à Chalabre et dans le Quercorb.
        </p>

        <a
          href="/cours"
          class="inline-flex items-center gap-3 bg-terracotta text-white px-8 py-4 text-sm font-medium hover:bg-terracotta/90 transition-colors"
        >
          Découvrir les cours
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>

      </div>
    </section>

    <!-- ── Courses ─────────────────────────────────────────────────────── -->
    <section class="py-24 px-6" id="cours">
      <div class="max-w-6xl mx-auto">

        <div class="mb-14">
          <p class="text-sm font-semibold text-sage mb-3">Nos cours</p>
          <h2 class="font-display text-4xl sm:text-5xl text-ink">Ce que nous proposons</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {courses.map((course) => (
            <a
              href={course.href}
              class="group bg-warm-grey p-8 flex flex-col gap-5 border border-transparent hover:border-sage transition-all duration-300"
            >
              <span class="text-xs font-mono text-ink/25 tracking-widest">{course.number}</span>
              <h3 class="font-display text-xl text-ink leading-snug">{course.name}</h3>
              <p class="text-sm text-ink/60 leading-relaxed flex-1">{course.description}</p>
              <span class="flex items-center gap-1.5 text-sm text-sage font-medium group-hover:gap-2.5 transition-all duration-200">
                Découvrir
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </span>
            </a>
          ))}
        </div>

      </div>
    </section>

    <!-- ── About teaser ────────────────────────────────────────────────── -->
    <section class="py-24 px-6 bg-warm-grey/40">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

          <div>
            <p class="text-sm font-semibold text-sage mb-3">À propos</p>
            <h2 class="font-display text-4xl sm:text-5xl text-ink leading-tight">
              Le français par<br />
              <span class="stroke-underline">quelqu'un du coin</span>
            </h2>
          </div>

          <div>
            <p class="text-lg text-ink/75 leading-relaxed mb-5">
              Installée à Chalabre depuis plus de dix ans, j'enseigne le français
              à des résidents étrangers qui veulent vraiment s'enraciner dans la vie
              locale&nbsp;— pas seulement survivre aux conversations.
            </p>
            <p class="text-lg text-ink/75 leading-relaxed mb-10">
              Mes cours partent de la réalité du Quercorb&nbsp;: les marchés, la mairie,
              les voisins, les médecins. Un français qui sert, appris dans un cadre
              bienveillant et sans jugement.
            </p>
            <a
              href="/a-propos"
              class="inline-flex items-center gap-2 text-sage font-medium hover:gap-3 transition-all duration-200"
            >
              En savoir plus
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>

        </div>
      </div>
    </section>

    <!-- ── Contact CTA ─────────────────────────────────────────────────── -->
    <section class="py-24 px-6 bg-sage">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="font-display text-4xl sm:text-5xl text-linen leading-tight mb-5">
          Prêt·e à commencer ?
        </h2>
        <p class="text-linen/65 text-lg leading-relaxed mb-10">
          Contactez-moi pour discuter de vos objectifs et trouver la formule qui vous convient.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center gap-3 bg-terracotta text-white px-8 py-4 text-sm font-medium hover:bg-terracotta/90 transition-colors"
        >
          Prendre contact
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </section>

  </main>

</Layout>
